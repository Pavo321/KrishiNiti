# KrishiNiti Environment Variables
# Copy this to .env and fill in values. NEVER commit .env

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password_min_20_chars
DATABASE_URL=postgresql://krishiniti_app:${POSTGRES_PASSWORD}@localhost:5432/krishiniti

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0

# ── WhatsApp Business API (Meta Cloud API) ────────────────────────────────────
# Get from: https://developers.facebook.com/apps → Your App → WhatsApp → API Setup
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=          # for webhook HMAC-SHA256 verification

# ── PII Encryption ────────────────────────────────────────────────────────────
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
PII_ENCRYPTION_KEY=

# ── External Data APIs ────────────────────────────────────────────────────────
# Free registration at https://data.gov.in → My Account → My API Keys
DATA_GOV_API_KEY=

# ── App Config ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development       # development | staging | production
